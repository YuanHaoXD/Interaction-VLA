# 复制为 .env 并填入真实值（.env 不要提交）。
# 一步API（yibuapi）中转站，OpenAI 兼容接口。文档: https://yibuapi.apifox.cn/
BASE_URL="https://yibuapi.com/v1"
API_KEY="sk-0azNkywVnc51x2ai4TPY4PI5Sum2ZR8a5LobWa0iT3rweRNa"

# 模型与调用参数（都有默认值，按需覆盖）
MODEL_NAME="gemini-2.5-flash"
MAX_WORKERS="20"
MAX_TOKENS="512"

# 关思考（默认开）。实测在 yibuapi 上默认思考、每次烧 ~250 reasoning token；
# 关后 ~90% 调用仅 ~10 token、省约 7×，判断质量等价。设 "0" 可开思考。
THINK_OFF="1"
THINKING_BUDGET="0"

# reasoning_effort 在 yibuapi 上【无效】，留空即可（仅换平台时可能用到）。
REASONING_EFFORT=""
